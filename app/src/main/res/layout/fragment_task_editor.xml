<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:padding="@dimen/padding_large">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/taskEditorTitle"
            style="@style/PetPlanner.Text.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Task editor" />

        <TextView
            style="@style/PetPlanner.Text.Subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Create or edit a task with title, schedule, and notes." />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Task title"
            android:textColor="@color/onBackgroundSecondary"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/taskTitleInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Enter task title"
            android:inputType="text" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Notes"
            android:textColor="@color/onBackgroundSecondary"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/taskNotesInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Optional task notes"
            android:inputType="textMultiLine"
            android:minLines="3" />

        <Button
            android:id="@+id/saveTaskButton"
            style="@style/PetPlanner.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Save task" />

    </LinearLayout>
</ScrollView>
