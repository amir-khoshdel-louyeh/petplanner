<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:padding="@dimen/padding_large">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/onboardingTitle"
            style="@style/PetPlanner.Text.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_title" />

        <TextView
            android:id="@+id/onboardingSubtitle"
            style="@style/PetPlanner.Text.Subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/onboarding_subtitle" />

        <TextView
            android:id="@+id/stepIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/onboarding_step_one"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/stepOneContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium"
            android:background="@drawable/bg_card">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_pet_profile_title"
                android:textColor="@color/onBackground"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/petNameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="@string/pet_name_hint"
                android:inputType="textPersonName"
                android:background="@drawable/bg_small_card"
                android:padding="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pet_type_label"
                android:textColor="@color/onBackgroundSecondary"
                android:textSize="14sp"
                android:layout_marginTop="12dp" />

            <RadioGroup
                android:id="@+id/petTypeRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/petTypeDogRadio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pet_type_dog"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/petTypeCatRadio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:text="@string/pet_type_cat" />
            </RadioGroup>

            <EditText
                android:id="@+id/petBreedInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/pet_breed_hint"
                android:inputType="text"
                android:background="@drawable/bg_small_card"
                android:padding="14dp" />

            <EditText
                android:id="@+id/petAgeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/pet_age_hint"
                android:inputType="number"
                android:digits="0123456789"
                android:background="@drawable/bg_small_card"
                android:padding="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:weightSum="3">

                <EditText
                    android:id="@+id/petWeightInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:hint="@string/pet_weight_hint"
                    android:inputType="numberDecimal"
                    android:digits="0123456789."
                    android:background="@drawable/bg_small_card"
                    android:padding="14dp" />

                <Spinner
                    android:id="@+id/weightUnitSpinner"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_small_card"
                    android:padding="12dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/onboarding_pet_photo_title"
                android:textColor="@color/onBackgroundSecondary"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/petPhotoPreview"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_small_card"
                android:padding="8dp"
                android:scaleType="centerCrop"
                android:contentDescription="Pet photo preview" />

            <Button
                android:id="@+id/choosePhotoButton"
                style="@style/PetPlanner.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/onboarding_choose_photo" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/stepTwoContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium"
            android:background="@drawable/bg_card"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/onboarding_user_profile_title"
                android:textColor="@color/onBackgroundSecondary"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/userNameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/user_name_hint"
                android:inputType="textPersonName"
                android:background="@drawable/bg_small_card"
                android:padding="14dp" />

            <EditText
                android:id="@+id/userAgeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/user_age_hint"
                android:inputType="number"
                android:digits="0123456789"
                android:background="@drawable/bg_small_card"
                android:padding="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/user_gender_label"
                android:textColor="@color/onBackgroundSecondary"
                android:textSize="14sp" />

            <RadioGroup
                android:id="@+id/userGenderRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/userGenderMaleRadio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/gender_male"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/userGenderFemaleRadio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:text="@string/gender_female" />

                <RadioButton
                    android:id="@+id/userGenderOtherRadio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:text="@string/gender_other" />
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/onboarding_language_label"
                android:textColor="@color/onBackgroundSecondary"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/languageSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_small_card"
                android:padding="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/onboarding_reminders_label"
                android:textColor="@color/onBackgroundSecondary"
                android:textSize="14sp" />

            <Switch
                android:id="@+id/remindersSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/onboarding_reminders_description" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <Button
                android:id="@+id/backButton"
                style="@style/PetPlanner.Button.Primary"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:text="@string/back_button"
                android:visibility="gone" />

            <Button
                android:id="@+id/nextButton"
                style="@style/PetPlanner.Button.Primary"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:text="@string/next_button" />

            <Button
                android:id="@+id/finishButton"
                style="@style/PetPlanner.Button.Primary"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:background="@drawable/bg_button_success"
                android:text="@string/finish_button"
                android:textColor="@android:color/white"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
