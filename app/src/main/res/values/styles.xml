<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="PetPlanner.Text.Title" parent="TextAppearance.AppCompat.Large">
        <item name="android:textColor">@color/onBackground</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PetPlanner.Text.Subtitle" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textColor">@color/onBackgroundSecondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="PetPlanner.Card" parent="Widget.AppCompat.CardView">
        <item name="cardUseCompatPadding">true</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/cardBackground</item>
    </style>
</resources>
